      "source": [
        "# 消費税を加えた金額を返す関数\n",
        "def calculate_tax(price, tax_rate):\n",
        "    return price * (1 + tax_rate / 100)\n",
        "\n",
        "\n",
        "# 第1引数：商品の金額110、第2引数：消費税10%\n",
        "result = calculate_tax(110, 10)\n",
        "\n",
        "# 計算結果を表示\n",
        "print(result)"
      ]
    }
